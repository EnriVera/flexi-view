{
  "name": "flexi-view",
  "version": "0.1.0",
  "description": "Framework-agnostic multi-view data library built with Web Components",
  "type": "module",
  "main": "dist/flexi-view.umd.js",
  "module": "dist/flexi-view.es.js",
  "types": "src/index.d.ts",
  "files": [
    "dist",
    "src/index.d.ts"
  ],
  "exports": {
    ".": {
      "import": "./dist/flexi-view.es.js",
      "types": "./src/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EnriVera/flexi-view.git"
  },
  "homepage": "https://github.com/EnriVera/flexi-view#readme",
  "keywords": [
    "web-components",
    "lit",
    "data-grid",
    "table",
    "dataview",
    "cards",
    "list-view"
  ],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/EnriVera/flexi-view/issues"
  },
  "scripts": {
    "dev": "vite",
    "prebuild": "vitest run",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:wtr": "wtr",
    "test:e2e": "playwright test",
    "size": "size-limit",
    "publish": "npm run build && npm publish --access public"
  },
  "dependencies": {
    "lit": "^3.0.0"
  },
  "devDependencies": {
    "@esm-bundle/chai": "^4.3.4",
    "@playwright/test": "^1.40.0",
    "@size-limit/preset-small-lib": "^11.0.0",
    "@web/test-runner": "^0.18.0",
    "@web/test-runner-playwright": "^0.11.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.40.0",
    "size-limit": "^11.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
